{
    "configurations": [
        {
            "name": "Pico",
            "includePath": [
                "${workspaceFolder}/Firmware/RP2040/***",
                "${workspaceFolder}/Firmware/RP2040/src/**",
            ],
            "forcedInclude": [
                "${workspaceFolder}/Firmware/external/pico-sdk/src/common/pico_base_headers/include/pico.h"
            ],
            "defines": [
                "CFG_TUH_ENABLED=1",
                "CONFIG_OGXM_DEBUG=1"
            ],
            "cStandard": "c17",
            "cppStandard": "c++14",
            "intelliSenseMode": "linux-gcc-arm"
        }
    ],
    "version": 4
}