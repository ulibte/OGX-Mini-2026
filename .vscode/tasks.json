{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build OGX-Mini Debug",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "cd Firmware/RP2040 && rm -rf build && cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Debug -DOGXM_BOARD=PI_PICO -DMAX_GAMEPADS=1 && cmake --build build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        }
    ]
}